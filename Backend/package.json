{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --coverageDirectory=coverage/unit",
    "test:manual": "COLLECT_COVERAGE=true npx c8 --all --reporter=json --report-dir=coverage/manual --exclude 'node_modules' --exclude 'coverage' node src/index.js",
    "coverage:collect": "echo 'Note: Coverage is now saved automatically in coverage/manual/coverage-final.json when you stop the server (Ctrl+C).'",
    "coverage:merge": "rm -rf .nyc_output && mkdir -p .nyc_output && cp coverage/unit/coverage-final.json .nyc_output/unit.json 2>/dev/null || true && cp coverage/manual/coverage-final.json .nyc_output/manual.json 2>/dev/null || true && nyc report --reporter=html --reporter=text"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "cron": "^4.4.0",
    "dotenv": "^17.2.3",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.2",
    "osmtogeojson": "^3.0.0-beta.5",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.11",
    "nyc": "^18.0.0",
    "supertest": "^7.2.2"
  }
}
